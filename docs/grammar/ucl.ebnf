<<< =========================================================
   UCL — Universal Configuration Language
   Complete EBNF Grammar (max)
   Features: config, expressions, profiles, modules, macros
   ========================================================= >>>

program         ::= WS? { toplevel WS? } EOF ;

<<< ===================== Top-level ===================== >>>

toplevel        ::= section
                  | assignment
                  | profile_decl
                  | module_decl
                  | import_decl
                  | macro_decl
                  | template_decl
                  | schema_decl
                  | comment ;

<<< ===================== Sections ===================== >>>

section         ::= ident WS? "{" WS? { section_item WS? } "}" ;

section_item    ::= assignment
                  | section
                  | include_stmt
                  | conditional
                  | comment ;

<<< ===================== Assignments ===================== >>>

assignment      ::= key WS? "=" WS? expr ;

key             ::= ident { "." ident } ;

<<< ===================== Expressions ===================== >>>

expr            ::= logical_or ;

logical_or      ::= logical_and { WS? "||" WS? logical_and } ;

logical_and     ::= equality { WS? "&&" WS? equality } ;

equality        ::= comparison { WS? ( "==" | "!=" ) WS? comparison } ;

comparison      ::= term { WS? ( "<" | "<=" | ">" | ">=" ) WS? term } ;

term            ::= factor { WS? ( "+" | "-" ) WS? factor } ;

factor          ::= unary { WS? ( "*" | "/" | "%" ) WS? unary } ;

unary           ::= ( "!" | "-" ) unary
                  | primary ;

primary         ::= literal
                  | variable
                  | function_call
                  | list
                  | map
                  | "(" WS? expr WS? ")" ;

<<< ===================== Literals ===================== >>>

literal         ::= string
                  | number
                  | boolean
                  | null ;

boolean         ::= "true" | "false" ;
null            ::= "null" ;

number          ::= int | float ;

int             ::= digit { digit | "_" } ;
float           ::= digit { digit | "_" } "." digit { digit | "_" } ;

string          ::= "\"" { string_char } "\"" ;

<<< ===================== Collections ===================== >>>

list            ::= "[" WS? [ expr { WS? "," WS? expr } ] WS? "]" ;

map             ::= "{" WS? [ map_entry { WS? "," WS? map_entry } ] WS? "}" ;

map_entry       ::= key WS? ":" WS? expr ;

<<< ===================== Variables ===================== >>>

variable        ::= "$" ident ;

<<< ===================== Functions ===================== >>>

function_call   ::= ident WS? "(" WS? [ expr_list ] WS? ")" ;

expr_list       ::= expr { WS? "," WS? expr } ;

<<< ===================== Includes ===================== >>>

include_stmt    ::= "include" WS1 string ;

<<< ===================== Profiles ===================== >>>

profile_decl    ::= "profile" WS1 ident WS? "{" WS? { section_item WS? } "}" ;

<<< ===================== Modules ===================== >>>

module_decl     ::= "module" WS1 ident WS? "{" WS? { section_item WS? } "}" ;

import_decl     ::= "import" WS1 string ;

<<< ===================== Macros ===================== >>>

macro_decl      ::= "macro" WS1 ident WS? "(" WS? [ param_list ] WS? ")" WS? block ;

template_decl   ::= "template" WS1 ident WS? block ;

param_list      ::= ident { WS? "," WS? ident } ;

block           ::= "{" WS? { statement WS? } "}" ;

statement       ::= assignment
                  | expr
                  | conditional
                  | comment ;

<<< ===================== Conditionals ===================== >>>

conditional     ::= "if" WS1 expr WS? block
                    { WS? "elif" WS1 expr WS? block }
                    [ WS? "else" WS? block ] ;

<<< ===================== Schema ===================== >>>

schema_decl     ::= "schema" WS1 ident WS? "{" WS? { schema_item WS? } "}" ;

schema_item     ::= key WS? ":" WS? type_expr [ WS? constraint_list ] ;

type_expr       ::= "string"
                  | "number"
                  | "bool"
                  | "list" "<" type_expr ">"
                  | "map" "<" type_expr "," type_expr ">"
                  | ident ;

constraint_list ::= "[" WS? constraint { WS? "," WS? constraint } WS? "]" ;

constraint      ::= "required"
                  | "min" "(" number ")"
                  | "max" "(" number ")"
                  | "regex" "(" string ")" ;

<<< ===================== Comments ===================== >>>

comment         ::= line_comment | block_comment ;

line_comment    ::= "#" { not_newline } ;
block_comment   ::= "<<<" { not_triple_close } ">>>" ;

<<< ===================== Lexical ===================== >>>

ident           ::= ident_start { ident_continue } ;

ident_start     ::= letter | "_" ;
ident_continue  ::= letter | digit | "_" ;

digit           ::= "0".."9" ;
letter          ::= "a".."z" | "A".."Z" ;

string_char     ::= ? any char except " or newline ? ;

not_newline     ::= ? any char except newline ? ;
not_triple_close::= ? any char except ">>>" ? ;

WS              ::= { " " | "\t" | "\n" | "\r" } ;
WS1             ::= ( " " | "\t" | "\n" | "\r" ) { WS } ;

EOF             ::= ? end of file ? ;
