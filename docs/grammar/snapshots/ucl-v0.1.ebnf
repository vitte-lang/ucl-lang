(* ========================================================= *)
(* UCL v0.1 — Unified Configuration Language                 *)
(* Snapshot Grammar (stable baseline)                        *)
(* ========================================================= *)

program         = { toplevel } ;

(* --------------------------------------------------------- *)
(* Top-level                                                 *)
(* --------------------------------------------------------- *)

toplevel        = space_decl
                | import_decl
                | config_decl
                | profile_decl
                | schema_decl
                | macro_decl
                | assignment ;

(* --------------------------------------------------------- *)
(* Space / Module                                            *)
(* --------------------------------------------------------- *)

space_decl      = "space" , ws1 , path ;

import_decl     = "import" , ws1 , path , [ ws1 , "as" , ws1 , ident ] ;

(* --------------------------------------------------------- *)
(* Config / Data                                             *)
(* --------------------------------------------------------- *)

config_decl     = "config" , ws1 , ident , block ;

assignment      = ident , ws? , "=" , ws? , expr ;

(* --------------------------------------------------------- *)
(* Profile                                                   *)
(* --------------------------------------------------------- *)

profile_decl    = "profile" , ws1 , ident , block ;

(* --------------------------------------------------------- *)
(* Schema                                                    *)
(* --------------------------------------------------------- *)

schema_decl     = "schema" , ws1 , ident , schema_body ;

schema_body     = "{" , { schema_field } , "}" ;

schema_field    = ident , ":" , type_expr , [ "?" ] ;

(* --------------------------------------------------------- *)
(* Macro                                                     *)
(* --------------------------------------------------------- *)

macro_decl      = "macro" , ws1 , ident , macro_body ;

macro_body      = "{" , { macro_rule } , "}" ;

macro_rule      = "rule" , ws1 , pattern , ws1 , "=>" , ws1 , expr ;

(* --------------------------------------------------------- *)
(* Blocks                                                    *)
(* --------------------------------------------------------- *)

block           = "{" , { statement } , "}" ;

statement       = assignment
                | block
                | expr ;

(* --------------------------------------------------------- *)
(* Expressions                                               *)
(* --------------------------------------------------------- *)

expr            = or_expr ;

or_expr         = and_expr , { ws1 , "or" , ws1 , and_expr } ;

and_expr        = eq_expr , { ws1 , "and" , ws1 , eq_expr } ;

eq_expr         = rel_expr , { ws? , ( "==" | "!=" ) , ws? , rel_expr } ;

rel_expr        = add_expr , { ws? , ( "<" | "<=" | ">" | ">=" ) , ws? , add_expr } ;

add_expr        = mul_expr , { ws? , ( "+" | "-" ) , ws? , mul_expr } ;

mul_expr        = unary_expr , { ws? , ( "*" | "/" | "%" ) , ws? , unary_expr } ;

unary_expr      = ( "not" | "-" ) , unary_expr
                | postfix_expr ;

postfix_expr    = primary , { call | access | index } ;

call            = "(" , [ arg_list ] , ")" ;

access          = "." , ident ;

index           = "[" , expr , "]" ;

primary         = literal
                | ident
                | list
                | object
                | "(" , expr , ")" ;

arg_list        = expr , { "," , expr } ;

(* --------------------------------------------------------- *)
(* Literals                                                  *)
(* --------------------------------------------------------- *)

literal         = int
                | float
                | string
                | bool
                | "null" ;

list            = "[" , [ arg_list ] , "]" ;

object          = "{" , [ pair , { "," , pair } ] , "}" ;

pair            = ident , ":" , expr ;

(* --------------------------------------------------------- *)
(* Schema Types                                              *)
(* --------------------------------------------------------- *)

type_expr       = type_primary
                | list_type
                | map_type
                | union_type ;

type_primary    = ident
                | "int"
                | "string"
                | "bool"
                | "float" ;

list_type       = "[" , type_expr , "]" ;

map_type        = "map" , "<" , type_expr , "," , type_expr , ">" ;

union_type      = type_expr , "|" , type_expr ;

(* --------------------------------------------------------- *)
(* Patterns (macros / match)                                 *)
(* --------------------------------------------------------- *)

pattern         = ident
                | literal
                | ident , "(" , [ pattern_list ] , ")" ;

pattern_list    = pattern , { "," , pattern } ;

(* --------------------------------------------------------- *)
(* Path / Identifiers                                        *)
(* --------------------------------------------------------- *)

path            = ident , { ( "/" | "." ) , ident } ;

ident           = letter , { letter | digit | "_" } ;

(* --------------------------------------------------------- *)
(* Tokens                                                    *)
(* --------------------------------------------------------- *)

int             = digit , { digit | "_" } ;
float           = digit , { digit } , "." , digit , { digit } ;

string          = "\"" , { char } , "\""
                | "\"\"\"" , { raw_char } , "\"\"\"" ;

bool            = "true" | "false" ;

letter          = "a"…"z" | "A"…"Z" | "_" ;
digit           = "0"…"9" ;

char            = ? any char except " ? ;
raw_char        = ? any char except """ ? ;

ws              = { " " | "\t" | newline } ;
ws1             = ( " " | "\t" | newline ) , ws ;

newline         = "\n" | "\r\n" ;

(* ========================================================= *)
(* End of Grammar                                            *)
(* ========================================================= *)