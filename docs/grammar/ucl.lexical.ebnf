<<< =========================================================
   UCL — Lexical Specification (max)
   Unicode-aware, whitespace-sensitive, config + DSL hybrid
   ========================================================= >>>

<<< ===================== Character Sets ===================== >>>

unicode_char        ::= ? any valid Unicode scalar value ? ;

newline             ::= "\n" | "\r\n" ;
space               ::= " " | "\t" ;

WS                  ::= { space | newline } ;
WS_INLINE           ::= { space } ;
WS_REQUIRED         ::= space { space | newline } ;

<<< ===================== Identifiers ===================== >>>

ident               ::= ident_start { ident_continue } ;

ident_start         ::= letter | "_" ;
ident_continue      ::= letter | digit | "_" | "-" ;

letter              ::= unicode_letter ;
digit               ::= "0".."9" ;

unicode_letter      ::= ? Unicode category: Letter ? ;

<<< ===================== Keywords ===================== >>>

keyword             ::= "profile"
                      | "module"
                      | "import"
                      | "include"
                      | "macro"
                      | "template"
                      | "schema"
                      | "if"
                      | "elif"
                      | "else"
                      | "true"
                      | "false"
                      | "null"
                      | "use"
                      | "give"
                      ;

<<< ===================== Literals ===================== >>>

literal             ::= string
                      | number
                      | boolean
                      | null ;

boolean             ::= "true" | "false" ;
null                ::= "null" ;

<<< ----- Numbers ----- >>>

number              ::= int | float ;

int                 ::= dec_int | hex_int | bin_int | oct_int ;

dec_int             ::= digit { digit | "_" } ;

hex_int             ::= "0x" hex_digit { hex_digit | "_" } ;
bin_int             ::= "0b" bin_digit { bin_digit | "_" } ;
oct_int             ::= "0o" oct_digit { oct_digit | "_" } ;

hex_digit           ::= digit | "a".."f" | "A".."F" ;
bin_digit           ::= "0" | "1" ;
oct_digit           ::= "0".."7" ;

float               ::= digit { digit | "_" } "." digit { digit | "_" }
                        [ exponent ] ;

exponent            ::= ("e" | "E") [ "+" | "-" ] digit { digit } ;

<<< ----- Strings ----- >>>

string              ::= "\"" { string_char } "\"" 
                      | raw_string ;

string_char         ::= escape_seq
                      | ? any char except " or newline ? ;

escape_seq          ::= "\\" ( "\"" | "\\" | "n" | "r" | "t" | "u" hex4 ) ;

hex4                ::= hex_digit hex_digit hex_digit hex_digit ;

raw_string          ::= "r\"" { raw_char } "\"" ;

raw_char            ::= ? any char except unescaped " ? ;

<<< ===================== Variables ===================== >>>

variable            ::= "$" ident ;

<<< ===================== Operators ===================== >>>

operator            ::= "==" | "!="
                      | "<=" | ">=" | "<" | ">"
                      | "+" | "-" | "*" | "/" | "%"
                      | "&&" | "||"
                      | "!" ;

assign_op           ::= "=" ;

dot                 ::= "." ;
colon               ::= ":" ;
comma               ::= "," ;

<<< ===================== Delimiters ===================== >>>

lparen              ::= "(" ;
rparen              ::= ")" ;

lbrace              ::= "{" ;
rbrace              ::= "}" ;

lbracket            ::= "[" ;
rbracket            ::= "]" ;

<<< ===================== Comments ===================== >>>

comment             ::= line_comment | block_comment ;

line_comment        ::= "#" { not_newline } ;

block_comment       ::= "<<<" block_content ">>>" ;

block_content       ::= { block_char } ;

block_char          ::= ? any char except ">>>" ? ;

not_newline         ::= ? any char except newline ? ;

<<< ===================== Paths & Keys ===================== >>>

path                ::= ident { ( "." | "/" ) ident } ;

key                 ::= ident { "." ident } ;

<<< ===================== Functions ===================== >>>

function_name       ::= ident ;

<<< ===================== Special Forms ===================== >>>

env_call            ::= "env" "(" string ")" ;

<<< ===================== Tokenization Rules ===================== >>>

token               ::= keyword
                      | ident
                      | literal
                      | operator
                      | assign_op
                      | variable
                      | lparen | rparen
                      | lbrace | rbrace
                      | lbracket | rbracket
                      | comma | colon | dot
                      | comment ;

<<< ===================== Priority & Ambiguity ===================== >>>

<<< Longest match wins >>
<<< Keywords override identifiers >>
<<< Numbers parsed before identifiers when prefix matches >>
<<< Comments removed before parsing >>

<<< ===================== Ignored ===================== >>>

ignored             ::= WS | comment ;

<<< ===================== End ===================== >>>
