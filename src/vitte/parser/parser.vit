space ucl/parser

pull ucl/token
pull ucl/ast

form Parser
  tokens List of Token
  pos Int
.end

proc current(p Parser) -> Token
  ret p.tokens[p.pos]
.end

proc advance(p Parser)
  p.pos = p.pos + 1
.end

proc expect(p Parser, kind TokenKind)
  if current(p).kind != kind
    # error handling
  .end
  advance(p)
.end
