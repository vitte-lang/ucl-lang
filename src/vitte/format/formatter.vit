space ucl/format/formatter

pull ucl/ast
pull ucl/format/printer
pull ucl/format/style

proc format_program(p Program) -> String
  make pr = Printer { out = "", level = 0, style = default() }

  loop each s in p.items
    format_stmt(pr, s)
    newline(pr)
  .end

  ret pr.out
.end

proc format_stmt(pr Printer, s Stmt)
  # simplified dispatcher
.end

proc format_expr(pr Printer, e Expr)
  # simplified
.end
