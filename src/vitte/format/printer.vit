space ucl/format/printer

pull ucl/format/style

form Printer
  out String
  level Int
  style Style
.end

proc write(p Printer, s String)
  p.out = p.out + s
.end

proc newline(p Printer)
  write(p, p.style.newline)
  make i = 0
  loop while i < p.level
    write(p, p.style.indent)
    i = i + 1
  .end
.end

proc indent(p Printer)
  p.level = p.level + 1
.end

proc dedent(p Printer)
  p.level = p.level - 1
.end
