space ucl/fs/cache

form CacheEntry
  path String
  content String
.end

form Cache
  entries List of CacheEntry
.end

proc put(c Cache, path String, content String)
  c.entries.push(CacheEntry { path = path, content = content })
.end

proc get(c Cache, path String) -> String
  loop each e in c.entries
    if e.path == path
      ret e.content
    .end
  .end
  ret ""
.end
