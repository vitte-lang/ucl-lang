space ucl/fs/virtual_fs

form VirtualFile
  path String
  content String
.end

form VirtualFS
  files List of VirtualFile
.end

proc add(fs VirtualFS, path String, content String)
  fs.files.push(VirtualFile { path = path, content = content })
.end

proc get(fs VirtualFS, path String) -> String
  loop each f in fs.files
    if f.path == path
      ret f.content
    .end
  .end
  ret ""
.end
