space ucl/hir/lower

pull ucl/ast
pull ucl/hir/node
pull ucl/hir/path

proc lower_program(ast Program) -> HProgram
  make nodes = []
  loop each s in ast.items
    nodes.push(lower_stmt(s))
  .end
  ret HProgram { nodes = nodes }
.end

proc lower_stmt(s Stmt) -> HNode
  # simplified lowering
  ret HNode
.end
