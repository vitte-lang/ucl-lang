space ucl/hir/symbol

form Symbol
  name String
  value String
.end

form SymbolTable
  entries List of Symbol
.end

proc insert(table SymbolTable, name String, value String)
  table.entries.push(Symbol { name = name, value = value })
.end

proc lookup(table SymbolTable, name String) -> String
  loop each s in table.entries
    if s.name == name
      ret s.value
    .end
  .end
  ret ""
.end
