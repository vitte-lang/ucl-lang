space ucl/hir/node

form HProgram
  nodes List of HNode
.end

pick HNode
  Assign HAssign
  Section HSection
  If HIf
.end

form HAssign
  path String
  value HValue
.end

form HSection
  name String
  body List of HNode
.end

form HIf
  cond String
  then_branch List of HNode
  else_branch List of HNode
.end

pick HValue
  Str String
  Int Int
  Bool Bool
  Null
  List List of HValue
.end
