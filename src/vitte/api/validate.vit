<<< =========================================================
   Vitte UCL Validation Engine 
   multi-pass / symbols / types / schema / imports / LSP-ready
   ========================================================= >>>

space vitte/api/validate

from vitte/api/parse import parse
from vitte/api/export import export_json


<<< ================= Diagnostics ================= >>>

form Position {
  line: int
  column: int
  file: string
}

form Span {
  start: Position
  end: Position
}

form Diagnostic {
  message: string
  code: string
  severity: string
  span: Span
  notes: [string]
  hints: [string]
}

form ValidationResult {
  ok: bool
  diagnostics: [Diagnostic]
}

form Symbol {
  name: string
  kind: string
}

form Context {
  symbols: [Symbol]
}


<<< ================= Helpers ================= >>>

proc pos(line: int, col: int, file: string) -> Position {
  give Position { line: line column: col file: file }
}

proc span(line: int, col: int, file: string) -> Span {
  let p = pos(line, col, file)
  give Span { start: p end: p }
}

proc diag(msg: string, code: string, sev: string, line: int, col: int, file: string) -> Diagnostic {
  give Diagnostic {
    message: msg
    code: code
    severity: sev
    span: span(line, col, file)
    notes: []
    hints: []
  }
}

proc ok() -> ValidationResult {
  give ValidationResult { ok: true diagnostics: [] }
}

proc fail(ds: [Diagnostic]) -> ValidationResult {
  give ValidationResult { ok: false diagnostics: ds }
}


<<< ================= Symbol Table ================= >>>

proc has_symbol(ctx: Context, name: string) -> bool {
  loop each s in ctx.symbols {
    if s.name == name {
      give true
    }
  }
  give false
}

proc add_symbol(ctx: Context, name: string, kind: string) -> Context {
  let s = Symbol { name: name kind: kind }
  give Context { symbols: ctx.symbols + [s] }
}


<<< ================= Pass 1: Structure ================= >>>

proc pass_structure(tree: any) -> [Diagnostic] {
  let ds: [Diagnostic] = []

  if tree == null {
    give [diag("empty AST", "E000", "error", 0, 0, "<input>")]
  }

  give ds
}


<<< ================= Pass 2: Symbols ================= >>>

proc pass_symbols(tree: any, ctx: Context) -> [Diagnostic] {
  let ds: [Diagnostic] = []

  <<< pseudo walk >>>
