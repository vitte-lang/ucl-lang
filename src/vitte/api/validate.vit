  <<< NOTE: remplacer par un vrai walker AST >>>

  give ds
}


<<< ================= Pass 3: Types ================= >>>

proc pass_types(tree: any) -> [Diagnostic] {
  let ds: [Diagnostic] = []

  <<< ex: incompatible types, opérations invalides >>>

  give ds
}


<<< ================= Pass 4: Schema ================= >>>

proc pass_schema(tree: any) -> [Diagnostic] {
  let ds: [Diagnostic] = []

  <<< branch vers validator schema Python / Vitte >>>

  give ds
}


<<< ================= Pass 5: Imports ================= >>>

proc pass_imports(tree: any) -> [Diagnostic] {
  let ds: [Diagnostic] = []

  <<< vérifier modules, cycles, résolution >>>

  give ds
}


<<< ================= Validation Engine ================= >>>

proc validate_ast(tree: any) -> ValidationResult {
  let ctx = Context { symbols: [] }
  let ds: [Diagnostic] = []

  <<< ---- Pass 1 ---- >>>
  let p1 = pass_structure(tree)
  if p1 != [] { ds = ds + p1 }

  <<< ---- Pass 2 ---- >>>
  let p2 = pass_symbols(tree, ctx)
  if p2 != [] { ds = ds + p2 }

  <<< ---- Pass 3 ---- >>>
  let p3 = pass_types(tree)
  if p3 != [] { ds = ds + p3 }

  <<< ---- Pass 4 ---- >>>
  let p4 = pass_schema(tree)
  if p4 != [] { ds = ds + p4 }

  <<< ---- Pass 5 ---- >>>
  let p5 = pass_imports(tree)
  if p5 != [] { ds = ds + p5 }

  if ds == [] {
    give ok()
  }

  give fail(ds)
}


<<< ================= Public API ================= >>>

proc validate(code: string) -> ValidationResult {
  let tree = parse(code)

  if tree == null {
    give fail([
      diag("parse failed", "E_PARSE", "error", 0, 0, "<input>")
    ])
  }

  give validate_ast(tree)
}


<<< ================= JSON API ================= >>>

proc validate_json(code: string) -> string {
  give export_json(validate(code))
}


<<< ================= LSP API ================= >>>

proc validate_lsp(code: string) -> [Diagnostic] {
  let r = validate(code)
  give r.diagnostics
}


<<< ================= Strict Mode ================= >>>

proc validate_or_fail(code: string) {
  let r = validate(code)

  if r.ok == false {
    <<< hook futur panic/log >>>
    give
  }
}
