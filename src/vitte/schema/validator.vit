space ucl/schema/validator

pull ucl/schema/types
pull ucl/schema/rules
pull ucl/schema/constraints
pull ucl/schema/diagnostics

proc validate(schema Schema, data Map of String to String)
  loop each f in schema.fields
    if f.name not in data
      report(SchemaError { message = "missing field", field = f.name })
    .end
  .end
.end
