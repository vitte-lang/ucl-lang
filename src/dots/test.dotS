<<< =========================================================
   DotS Test Framework — MAX ∞
   unit / integration / property / fuzz / mock / coverage
   parallel / assertions / CI-ready / reproducible
   ========================================================= >>>

.module.test.

.import.core.io.
.import.core.fs.
.import.core.time.
.import.core.list.
.import.core.map.
.import.core.str.
.import.core.math.
.import.core.random.
.import.core.thread.
.import.core.diff.
.import.core.json.
.import.core.sys.

<<< ===================== Config ===================== >>>

.set.parallelism.8.
.set.timeout_default.60.
.set.fail_fast.false.
.set.seed.12345.

.set.tests.list.new.
.set.results.list.new.

<<< ===================== Logging ===================== >>>

.fn.log.msg.
  .call.io.print."[test] ".$msg.
.end.

<<< ===================== Test Definition ===================== >>>

.fn.test.define.name.fn_ptr.type.timeout.
  .set.t.map.new.
  .set.t.name.$name.
  .set.t.fn.$fn_ptr.
  .set.t.type.$type.
  .set.t.timeout.$timeout.
  .call.list.push.$tests.$t.
.end.

<<< ===================== Assertions ===================== >>>

.fn.assert.eq.a.b.
  .if $a != $b {
    .call.fail.(str.concat."assert eq fail " $a " != " $b).
  }.
.end.

.fn.assert.true.cond.
  .if !$cond {
    .call.fail."assert true fail".
  }.
.end.

.fn.assert.contains.s.sub.
  .if !call.str.contains.$s.$sub {
    .call.fail."assert contains fail".
  }.
.end.

.fn.fail.msg.
  .call.sys.throw.$msg.
.end.

<<< ===================== Runner ===================== >>>

.fn.run.test.t.
  .set.start.call.time.now.

  .set.ok.call.process.exec_timeout.$t.fn.$t.timeout.

  .set.end.call.time.now.
  .set.duration.math.sub.$end.$start.

  .set.r.map.new.
  .set.r.name.$t.name.
  .set.r.ok.$ok.
  .set.r.duration.$duration.

  .call.list.push.$results.$r.

  .if !$ok && $fail_fast {
    .call.sys.exit.1.
  }.
.end.

<<< ===================== Parallel ===================== >>>

.fn.run.parallel.
  .set.queue.call.list.clone.$tests.

  .loop.i.0.$parallelism.
    .spawn.thread.
      .loop.
        .set.t.call.list.pop.$queue.
        .if $t == null { .break. }.
        .call.run.test.$t.
      .end.
    .end.
  .end.

  .call.thread.join_all.
.end.

<<< ===================== Property Testing ===================== >>>

.fn.prop.run.name.fn_ptr.
  .loop.i.0.1000.
    .set.input.call.random.int.0.1000.
    .call.$fn_ptr.$input.
  .end.
.end.

<<< ===================== Fuzz ===================== >>>

.fn.fuzz.run.name.fn_ptr.
  .loop.i.0.1000.
    .set.input.call.random.bytes.128.
    .call.$fn_ptr.$input.
  .end.
.end.

<<< ===================== Coverage ===================== >>>

.fn.coverage.collect.
  .ret.call.sys.coverage.
.end.

<<< ===================== Report ===================== >>>

.fn.report.print.
  .call.io.print."=== TEST REPORT ===".

  .set.ok_count.0.

  .each.r.$results.
    .if $r.ok {
      .set.ok_count.math.add.$ok_count.1.
      .call.io.print.(str.concat."[OK] " $r.name).
    } else {
      .call.io.print.(str.concat."[FAIL] " $r.name).
    }.
  .end.

  .call.io.print.(str.concat
    "passed=" $ok_count
    " total=" (list.len.$results)).
.end.

<<< ===================== CI ===================== >>>

.fn.ci.run.
  .call.run.parallel.
  .call.report.print.

  .set.fail.false.

  .each.r.$results.
    .if !$r.ok {
      .set.fail.true.
    }.
  .end.

  .if $fail {
    .call.sys.exit.1.
  }.
.end.

<<< ===================== Sample Tests ===================== >>>

.fn.sample.add.
  .call.assert.eq.(math.add.1.2).3.
.end.

.fn.sample.prop.
  .call.assert.true.(math.add.$1.0 >= $1).
.end.

.fn.sample.fuzz.
  .call.assert.true.(str.len.$1 >= 0).
.end.

<<< register >>>

.fn.setup.
  .call.test.define."add_test".$sample.add."unit".10.
  .call.test.define."prop_test".$sample.prop."property".10.
  .call.test.define."fuzz_test".$sample.fuzz."fuzz".10.
.end.

<<< ===================== Entry ===================== >>>

.fn.main.
  .call.setup.
  .call.ci.run.
.end.

.entry.main.
